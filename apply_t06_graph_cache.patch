--- a/ggml_llama_gguf.c
+++ b/ggml_llama_gguf.c
@@ -328,6 +328,10 @@ int engine_init_backend(engine_t *e) {
 
 int engine_forward(engine_t *e, int n_tokens,
                    const int32_t *tokens, const int32_t *positions,
                    float *logits_out) {
+    /* T06: Graph caching for decode - reuse graph structure on single-token decode */
+    bool reuse_cached_graph = (n_tokens == 1 && e->cached_decode_graph != NULL);
+
     int H = e->hidden_dim, I = e->intermediate;
     int NH = e->n_heads, NKV = e->n_kv_heads, HD = e->head_dim;
 
@@ -347,7 +351,19 @@ int engine_forward(engine_t *e, int n_tokens,
     struct ggml_context *ctx = e->_persistent_ctx;
     if (!ctx) return -1;
 
-    struct ggml_cgraph *graph = ggml_new_graph_custom(ctx, GRAPH_SIZE, false);
+    struct ggml_cgraph *graph;
+    
+    if (reuse_cached_graph) {
+        /* Reuse cached decode graph - skip rebuilding */
+        graph = e->cached_decode_graph;
+    } else {
+        /* Build new graph (prefill or first decode) */
+        graph = ggml_new_graph_custom(ctx, GRAPH_SIZE, false);
+        
+        /* Cache this graph if it's a single-token decode for future reuse */
+        if (n_tokens == 1 && e->cached_decode_graph == NULL) {
+            /* Will cache after graph is built and finalized below */
+        }
+    }
 
     struct ggml_tensor *inp_tokens = ggml_new_tensor_1d(ctx, GGML_TYPE_I32, n_tokens);
     ggml_set_name(inp_tokens, "tokens");
@@ -478,6 +494,22 @@ int engine_forward(engine_t *e, int n_tokens,
     ggml_set_name(cur, e->return_hidden ? "hidden" : "logits");
 
     ggml_backend_sched_reset(e->sched);
+    
+    /* T06: Cache the graph if this is first decode pass */
+    if (!reuse_cached_graph && n_tokens == 1 && e->cached_decode_graph == NULL) {
+        /* Build graph first to get size, then duplicate into persistent context */
+        ggml_build_forward_expand(graph, cur);
+        size_t graph_size = ggml_graph_overhead_custom(graph->size, false);
+        
+        /* Create persistent context for cached graph */
+        e->cached_graph_ctx = ggml_init((struct ggml_init_params){
+            .mem_size   = graph_size,
+            .mem_buffer = NULL,
+            .no_alloc   = false
+        });
+        e->cached_decode_graph = ggml_graph_dup(e->cached_graph_ctx, graph);
+        /* Don't rebuild graph - use the one we just built */
+    } else {
         ggml_build_forward_expand(graph, cur);
+    }
+    
     if (!ggml_backend_sched_alloc_graph(e->sched, graph)) {
         return -2;
     }
