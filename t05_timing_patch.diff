# T05 Timing Instrumentation Patch for ggml_llama_gguf.c
# Adds microsecond-precision timing for:
# - Graph build time
# - Backend compute time  
# - Total forward time

--- a/ggml_llama_gguf.c
+++ b/ggml_llama_gguf.c
@@ -21,6 +21,7 @@
 #include <stdlib.h>
 #include <string.h>
 #include <stdio.h>
+#include <time.h>
 #include <math.h>
 
 #define MAX_LAYERS 64
@@ -44,6 +45,11 @@ typedef struct {
     int n_heads, n_kv_heads, head_dim;
     int vocab_size, n_ctx;
     float rms_eps, rope_theta;
+
+    /* T05: Timing instrumentation */
+    double t_graph_build_us;
+    double t_backend_compute_us;
+    int64_t token_count;
 
     /* Pre-allocated compute buffer (avoids malloc per token) */
     size_t compute_buf_size;
@@ -295,6 +301,19 @@ typedef struct {
     int return_hidden;  /* Skip lm_head for vLLM hidden states */
 } engine_t;
 
+/* T05: Microsecond-precision timing */
+static inline double get_time_us(void) {
+    struct timespec ts;
+    clock_gettime(CLOCK_MONOTONIC, &ts);
+    return (double)ts.tv_sec * 1e6 + (double)ts.tv_nsec / 1e3;
+}
+
+static inline void reset_timing(engine_t *e) {
+    e->t_graph_build_us = 0;
+    e->t_backend_compute_us = 0;
+    e->token_count = 0;
+}
+
 /* Forward declarations */
 int engine_forward(engine_t *e, int n_tokens, const int32_t *tokens, const int32_t *positions, float *logits_out);
 
@@ -330,6 +349,8 @@ int engine_forward(engine_t *e, int n_tokens,
                    const int32_t *tokens, const int32_t *positions,
                    float *logits_out) {
     int H = e->hidden_dim, I = e->intermediate;
+    double t_start = get_time_us();
+    e->token_count++;
 
     /* Reuse persistent context — ggml_reset is MUCH faster than init/free */
     if (!e->_persistent_ctx) {
@@ -351,6 +372,7 @@ int engine_forward(engine_t *e, int n_tokens,
     struct ggml_context *ctx = e->_persistent_ctx;
     if (!ctx) return -1;
 
+    double t_graph_start = get_time_us();
     struct ggml_cgraph *graph = ggml_new_graph_custom(ctx, GRAPH_SIZE, false);
 
     struct ggml_tensor *inp_tokens = ggml_new_tensor_1d(ctx, GGML_TYPE_I32, n_tokens);
@@ -477,6 +499,8 @@ int engine_forward(engine_t *e, int n_tokens,
     ggml_backend_sched_reset(e->sched);
     ggml_build_forward_expand(graph, cur);
     if (!ggml_backend_sched_alloc_graph(e->sched, graph)) {
+        e->t_graph_build_us += get_time_us() - t_graph_start;
+        e->t_backend_compute_us = 0;
         return -2;
     }
     ggml_backend_tensor_set(inp_tokens, tokens, 0, n_tokens * sizeof(int32_t));
@@ -484,6 +508,7 @@ int engine_forward(engine_t *e, int n_tokens,
     /* T06: Print graph topology for documentation */
     if (n_tokens == 1 && positions[0] < 2) {
         fprintf(stderr, "=== GGML Graph Topology (pos=%d, n_tokens=%d) ===\n", positions[0], n_tokens);
+        e->t_graph_build_us += get_time_us() - t_graph_start;
         fprintf(stderr, "Graph nodes: %d\n", ggml_graph_n_nodes(graph));
         int views=0, compute=0;
         for (int i = 0; i < ggml_graph_n_nodes(graph); i++) {
@@ -495,11 +520,26 @@ int engine_forward(engine_t *e, int n_tokens,
         }
         fprintf(stderr, "Breakdown: views=%d, compute=%d\n", views, compute);
     }
+
+    double t_compute_start = get_time_us();
     enum ggml_status status = ggml_backend_sched_graph_compute(e->sched, graph);
+    e->t_backend_compute_us += get_time_us() - t_compute_start;
+    
+    double t_total = get_time_us() - t_start;
+    
     if (status != GGML_STATUS_SUCCESS) {
         fprintf(stderr, "[engine] compute failed: %d\n", status);
         return -3;
     }
+
+    /* Print timing every 10 tokens */
+    if (e->token_count % 10 == 0) {
+        fprintf(stderr, "[Timing @ %ld tokens] Graph: %.1fµs, Compute: %.1fµs, Total: %.1fµs (%.1f TPS)\n",
+                (long)e->token_count,
+                e->t_graph_build_us,
+                e->t_backend_compute_us,
+                t_total,
+                1e6 / t_total);
+    }
 
     size_t out_dim = e->return_hidden ? e->hidden_dim : e->vocab_size;
     size_t out_size = (size_t)n_tokens * out_dim * sizeof(float);
